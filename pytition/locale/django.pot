#: pytition/petition/templates/admin/spam_page.html:734
msgid "Tests to avoid inappropriate petitions"
msgstr ""

#: pytition/petition/templates/admin/spam_page.html:737
msgid ""
"In order to avoid inappropriate petitions, we use detectors defined in "
"pytition/petition/spam_management/detectors. They are all called in pytition/"
"petition/spam_management/detector.py."
msgstr ""

#: pytition/petition/templates/admin/spam_page.html:741
msgid ""
"akismet_detector: uses Akismet's is_spam() function to detect spam content. "
"Returns 0, 1 or 2."
msgstr ""

#: pytition/petition/templates/admin/spam_page.html:742
msgid ""
"alt_profanity_check_detector: uses function predict_prob() from alt-"
"profanity-check library to detect profanity in english content. Returns 0, 1 "
"or 2."
msgstr ""

#: pytition/petition/templates/admin/spam_page.html:743
msgid ""
"keywords_detector: uses list of forbidden keywords defined in settings. "
"Returns 0 or 1."
msgstr ""

#: pytition/petition/templates/admin/spam_page.html:747
msgid ""
"Depending on the results of these detectors, automatic moderation or "
"monitoring actions are taken:"
msgstr ""

#: pytition/petition/templates/admin/spam_page.html:751
msgid "0: no spam, no moderation or monitoring."
msgstr ""

#: pytition/petition/templates/admin/spam_page.html:752
msgid "1: possible spam, strong monitoring."
msgstr ""

#: pytition/petition/templates/admin/spam_page.html:753
msgid "2: spam, moderation."
msgstr ""

#: pytition/petition/templates/admin/spam_page.html:757
msgid ""
